{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hazarsozer/crucible-cc/schemas/persona-finding.schema.json",
  "title": "PersonaFinding",
  "type": "object",
  "required": [
    "persona", "stage", "model_used", "started_at", "completed_at",
    "scope_assessed", "verdict", "score", "summary_quote", "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "persona": { "type": "string", "minLength": 1 },
    "stage": { "type": "integer", "enum": [1, 2, 3] },
    "model_used": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "scope_assessed": {
      "anyOf": [
        { "type": "array", "items": { "type": "string" }, "minItems": 0 },
        { "type": "string", "enum": ["all"] }
      ]
    },
    "verdict": { "type": "string", "enum": ["approve", "concerns", "block"] },
    "score": { "type": "integer", "minimum": 0, "maximum": 10 },
    "summary_quote": { "type": "string", "minLength": 1, "maxLength": 500 },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/Finding" }
    },
    "stage_handoff_notes": { "type": "string" }
  },
  "$defs": {
    "Finding": {
      "type": "object",
      "required": ["severity", "category", "title", "evidence", "explanation", "suggestion"],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "category": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 250 },
        "evidence": { "$ref": "#/$defs/Evidence" },
        "explanation": { "type": "string", "minLength": 1 },
        "suggestion": { "type": "string", "minLength": 1 }
      }
    },
    "Evidence": {
      "type": "object",
      "description": "Structured citation: path + line range. Personas reference source rather than inlining code into the JSON. The Aggregator reads the cited source at render time. This shape eliminates two failure modes: (a) fabricated code in findings, and (b) JSON content tripping security-pattern PreToolUse hooks. Whole-file findings: set line_start=1 and omit line_end.",
      "required": ["path", "line_start"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Project-root-relative path. Forward slashes. No leading slash, no ./ prefix."
        },
        "line_start": {
          "type": "integer",
          "minimum": 1,
          "description": "First line of the cited region (1-indexed)."
        },
        "line_end": {
          "type": "integer",
          "minimum": 1,
          "description": "Last line of the cited region (inclusive). Omit for single-line findings."
        },
        "symbol_name": {
          "type": "string",
          "minLength": 1,
          "description": "Optional. Name of the function/class/variable the finding concerns. Use prose form without parens (e.g. 'handleRequest', not 'handleRequest(...)')."
        }
      }
    }
  }
}
